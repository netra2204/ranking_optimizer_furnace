                              <operator activated="true" class="branch" compatibility="10.4.003" expanded="true" height="82" name="Branch (70)" width="90" x="179" y="34">
                                <parameter key="condition_type" value="expression"/>
                                <parameter key="expression" value="parse(%{fresh_feed_change})==0"/>
                                <parameter key="io_object" value="ANOVAMatrix"/>
                                <parameter key="return_inner_output" value="true"/>
                                <process expanded="true">
                                  <operator activated="true" class="subprocess" compatibility="10.4.003" expanded="true" height="82" name="Subprocess (14)" width="90" x="112" y="34">
                                    <process expanded="true">
                                      <operator activated="true" class="blending:generate_columns" compatibility="10.4.003" expanded="true" height="82" name="Generate Attributes (44)" width="90" x="45" y="34">
                                        <list key="function_descriptions">
                                          <parameter key="New_Overall_conversion" value="[Overall_conversion]+[conversion_lower_limit_in_grid]"/>
                                          <parameter key="New_Recycle_Ethane_Feed" value="(Feed_flow/(1+shc_ratio))*(100-[New_Overall_conversion])/100"/>
                                          <parameter key="New_Extra_Recycle_Ethane" value="New_Recycle_Ethane_Feed-Current_Recycle_Ethane_Feed"/>
                                          <parameter key="New_mixed_feed_margin" value="New_Extra_Recycle_Ethane*(1+shc_ratio)"/>
                                        </list>
