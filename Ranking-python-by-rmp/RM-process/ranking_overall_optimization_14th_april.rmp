                          <operator activated="true" class="generate_macro" compatibility="10.4.003" expanded="true" height="82" name="Generate Macro (149)" width="90" x="1117" y="85">
                            <list key="function_descriptions">
                              <parameter key="mixed_feed_margin" value="if(parse(%{fresh_feed_change})!=0,&#10;rint(parse(%{sum_upper_limit_feed})),&#10;rint(min(parse(%{sum_upper_limit_feed}),parse(%{count_of_good_fur})*2)))"/>
                              <parameter key="Extra_Recycle_Ethane" value="parse(%{mixed_feed_margin})/(1+parse(%{shc_ratio}))-parse(%{fresh_feed_quantity})"/>
                              <parameter key="upper_limit_change_in_recycle_ethane" value="parse(%{Extra_Recycle_Ethane})+parse(%{change_recycle_ethane_upper_limit})"/>
                              <parameter key="lower_limit_change_in_recycle_ethane" value="parse(%{Extra_Recycle_Ethane})+parse(%{change_recycle_ethane_lower_limit})"/>
                            </list>
                            <description align="center" color="transparent" colored="false" width="126">mixed_feed_margin&lt;br/&gt;Extra Recycle Ethan&lt;br/&gt;UL and LL recycle limit</description>
                          </operator>
