                    <list key="function_descriptions">
                      <parameter key="Margin_in_FG" value="if([fuel_gas_pressure_controlvalve_opening]&lt;parse(%{fuel_gas_pressure_controlvalve_opening_limit}) &amp;&amp; &#10;[fuel_gas_pressure]&lt;parse(%{fuel_gas_pressure_limit}), 1, 0)"/>
                      <parameter key="Margin_in_Steam" value="0"/>
                      <parameter key="Margin_in_Feed" value="if(pass8_mixed_feed_flow_controller_opening&lt;parse(%{margin_value_feed_limit}) &amp;&amp;&#10;pass7_mixed_feed_flow_controller_opening&lt;parse(%{margin_value_feed_limit}) &amp;&amp;&#10;pass6_mixed_feed_flow_controller_opening&lt;parse(%{margin_value_feed_limit}) &amp;&amp;&#10;pass5_mixed_feed_flow_controller_opening&lt;parse(%{margin_value_feed_limit}) &amp;&amp;&#10;pass4_mixed_feed_flow_controller_opening&lt;parse(%{margin_value_feed_limit}) &amp;&amp;&#10;pass3_mixed_feed_flow_controller_opening&lt;parse(%{margin_value_feed_limit}) &amp;&amp;&#10;pass2_mixed_feed_flow_controller_opening&lt;parse(%{margin_value_feed_limit}) &amp;&amp;&#10;pass1_mixed_feed_flow_controller_opening&lt;parse(%{margin_value_feed_limit}),1,0)"/>
                      <parameter key="Margin_in_Damper" value="if(damper_opening&lt;parse(%{damper_opening_limit}),1,0)"/>
                      <parameter key="Quench_OD_Gas_temp_margin" value="if(quench_tower_top_temperature&lt;parse(%{quench_ovhd_temp_limit}),1,1)"/>
                      <parameter key="CGC_suction_pressure_margin" value="if(cgc_suction_pressure&lt;parse(%{cgc_suction_pressure_limit}),1,1)"/>
                      <parameter key="C2_splitter_dp_margin" value="if(c2_splitter_dp&lt;parse(%{c2_splitter_dp_limit}),1,0)"/>
                      <parameter key="C2_splitter_btm_c2h4_mol_percent_margin" value="if(ethylene_in_ethane_recycle&lt;parse(%{c2_splitter_btm_c2h4_mol_percent_limit}),1,1)"/>
                      <parameter key="C2_splitter_reflux_pump_suction_temp_margin" value="1"/>
                      <parameter key="ERC_margin" value="if(erc_governor_opening&lt;parse(%{erc_governor_opening_limit})&amp;&amp; &#10;ethylene_compressure_suction_speed &lt; parse(%{ethylene_compressure_suction_speed_limit}),1,0)"/>
                      <parameter key="PRC_margin" value="if(prc_governor_opening&lt;parse(%{prc_governor_opening_limit})&#10;&amp;&amp; propylene_compressure_suction_speed &lt; parse(%{propylene_compressure_suction_speed_limit}),1,0)"/>
                      <parameter key="Total_margin" value="Margin_in_FG+Margin_in_Steam+Margin_in_Feed+Margin_in_Damper+&#10;Quench_OD_Gas_temp_margin+CGC_suction_pressure_margin+&#10;C2_splitter_dp_margin+C2_splitter_btm_c2h4_mol_percent_margin+C2_splitter_reflux_pump_suction_temp_margin+&#10;ERC_margin+PRC_margin"/>
                      <parameter key="Margin_in_Feed_lower_check" value="if(pass8_mixed_feed_flow_controller_opening&lt;parse(%{margin_in_feed_lower_check_limit}) &amp;&amp;&#10;pass7_mixed_feed_flow_controller_opening&lt;parse(%{margin_in_feed_lower_check_limit}) &amp;&amp;&#10;pass6_mixed_feed_flow_controller_opening&lt;parse(%{margin_in_feed_lower_check_limit}) &amp;&amp;&#10;pass5_mixed_feed_flow_controller_opening&lt;parse(%{margin_in_feed_lower_check_limit}) &amp;&amp;&#10;pass4_mixed_feed_flow_controller_opening&lt;parse(%{margin_in_feed_lower_check_limit}) &amp;&amp;&#10;pass3_mixed_feed_flow_controller_opening&lt;parse(%{margin_in_feed_lower_check_limit}) &amp;&amp;&#10;pass2_mixed_feed_flow_controller_opening&lt;parse(%{margin_in_feed_lower_check_limit}) &amp;&amp;&#10;pass1_mixed_feed_flow_controller_opening&lt;parse(%{margin_in_feed_lower_check_limit}),1,0)"/>
                      <parameter key="nox_margin" value="if([net_nox_emission]&gt;=parse(%{nox_emission_permissible_limit}),1,0)"/>
                      <parameter key="saturator_margin" value="if(parse(%{ethane_feed_saturator_drum_overhead_pressure})&#10;&gt;parse(%{saturator_drum_pressure_margin_limit}),1,0)"/>
                      <parameter key="shc_margin" value="if([shc_ratio_calculated]&#13;&gt;parse(%{shc_margin_limit}),1,0)"/>
                    </list>
                    <parameter key="keep_all_columns" value="true"/>
                    <parameter key="default_time_zone" value="Asia/Riyadh"/>
