                            <list key="function_descriptions">
                              <parameter key="Margin_condition_type" value="if(Margin_in_Feed==1 &amp;&amp; Margin_in_Feed_lower_check==0,0,&#10;if(Margin_in_Feed==1 &amp;&amp; Margin_in_Feed_lower_check==1,1,1000))"/>
                              <parameter key="upper_limit_feed" value="if([saturator_margin]==1,&#10;if(Margin_condition_type==1,4,if(Margin_condition_type==0,2,0)),&#10;if(Margin_condition_type==1,2,if(Margin_condition_type==0,1,0)))"/>
                              <parameter key="max_potential_total_feed" value="floor(min(4,parse(%{pass_step_change})*sum(&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass1_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass1],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass2_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass2],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass3_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass3],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass4_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass4],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass5_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass5],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass6_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass6],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass7_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass7],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass8_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass8])))"/>
