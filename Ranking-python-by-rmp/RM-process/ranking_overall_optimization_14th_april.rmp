                                                              <parameter key="New_Overall_conversion" value="if(parse(%{fresh_feed_change})&gt;0,&#10;min(parse(%{conversion_upper_limit_expansion_max_limit})+&#10;([Overall_conversion]-floor([Overall_conversion]))-1,&#10;[Overall_conversion]+parse(%{max_conversion_single_furnace_limit})),&#10;max(parse(%{conversion_lower_limit_expansion_max_limit})+&#10;([Overall_conversion]-floor([Overall_conversion])),&#10;[Overall_conversion]-parse(%{max_conversion_single_furnace_limit})))"/>
