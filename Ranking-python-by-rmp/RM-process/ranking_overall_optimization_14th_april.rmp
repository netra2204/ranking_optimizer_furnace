                          <operator activated="true" class="branch" compatibility="10.4.003" expanded="true" height="82" name="Branch (66)" width="90" x="1519" y="85">
                            <parameter key="condition_type" value="expression"/>
                            <parameter key="expression" value="parse(%{biasing_condition})==3"/>
                            <parameter key="io_object" value="ANOVAMatrix"/>
                            <parameter key="return_inner_output" value="false"/>
                            <process expanded="true">
                              <operator activated="true" class="blending:generate_columns" compatibility="10.4.003" expanded="true" height="82" name="Generate Attributes (1039)" width="90" x="112" y="34">
                                <list key="function_descriptions">
                                  <parameter key="conversion_lower_limit_in_grid" value="min(0,max(&#10;parse(%{conversion_bias_threshold_lower_limit}),&#10;-1*floor(([Overall_conversion]-parse(%{conversion_lower_limit_expansion_max_limit}))/0.5)*0.5))"/>
                                  <parameter key="conversion_upper_limit_in_grid" value="if([Furnace_condition]==&quot;Semi Good&quot;&amp;&amp; [percent_above_threshold]&gt;0,&#10;max(0,min(&#10;parse(%{conversion_bias_threshold_upper_limit}),&#10;floor((parse(%{conversion_upper_limit_expansion_max_limit})-[Overall_conversion])/0.5)*0.5)),0)"/>
                                  <parameter key="step_size_conversion" value="if(parse(%{count_of_no_good_fur})&lt;6,5,&#10;if(parse(%{count_of_no_good_fur})==6,3,&#10;if(parse(%{count_of_no_good_fur})==9,1,2)))"/>
                                  <parameter key="New_Feed_flow" value="Feed_flow"/>
                                </list>
                                <parameter key="keep_all_columns" value="true"/>
                                <parameter key="default_time_zone" value="Asia/Riyadh"/>
                                <description align="left" color="transparent" colored="false" width="126">Conversion grid limits and step size&lt;br&gt;New feed = Current Feed</description>
                              </operator>
                              <connect from_port="condition" to_op="Generate Attributes (1039)" to_port="table input"/>
                              <connect from_op="Generate Attributes (1039)" from_port="table output" to_port="input 1"/>
                              <portSpacing port="source_condition" spacing="0"/>
                              <portSpacing port="source_input 1" spacing="0"/>
                              <portSpacing port="sink_input 1" spacing="0"/>
                              <portSpacing port="sink_input 2" spacing="0"/>
                            </process>
                            <process expanded="true">
                              <operator activated="true" class="blending:generate_columns" compatibility="10.4.003" expanded="true" height="82" name="Generate Attributes (43)" width="90" x="45" y="34">
                                <list key="function_descriptions">
                                  <parameter key="conversion_lower_limit_in_grid" value="min(0,max(&#10;parse(%{conversion_bias_threshold_lower_limit}),&#10;-1*floor(([Overall_conversion]-parse(%{conversion_lower_limit_expansion_max_limit}))/0.5)*0.5))"/>
                                  <parameter key="conversion_upper_limit_in_grid" value="if(([Furnace_condition]==&quot;Good&quot;||[Furnace_condition]==&quot;Semi Good&quot;)&#10;&amp;&amp;(if(parse(%{fresh_feed_change})!=0,1==1,[Forecasted_runlength_rank]!=100)),eval(%{conversion_bias_threshold_upper_limit}),0)"/>
                                  <parameter key="conversion_upper_limit_in_grid" value="if([conversion_upper_limit_in_grid]==0,0,&#10;max(0,&#10;min(parse(%{conversion_bias_threshold_upper_limit}),&#10;floor((parse(%{conversion_upper_limit_expansion_max_limit})-[Overall_conversion])/0.5)*0.5)&#10;))"/>
                                </list>
