                            <process expanded="true">
                              <operator activated="true" class="blending:generate_columns" compatibility="10.4.003" expanded="true" height="82" name="Generate Attributes (330)" width="90" x="112" y="34">
                                <list key="function_descriptions">
                                  <parameter key="lower_limit_feed" value="if(parse(%{biasing_condition})==1 &amp;&amp; &#10;parse(%{mixed_feed_margin})==parse(%{sum_upper_limit_feed}),&#10;[upper_limit_feed],[lower_limit_feed])"/>
                                  <parameter key="step_size_feed" value="if(parse(%{biasing_condition})==1 &amp;&amp; &#10;parse(%{mixed_feed_margin})==parse(%{sum_upper_limit_feed}),&#10;if([step_size_feed]==0,0,1),[step_size_feed])"/>
                                  <parameter key="step_size_feed" value="if([lower_limit_feed]==[upper_limit_feed],0,[step_size_feed])"/>
                                </list>
