                                                        <list key="function_descriptions">
                                                          <parameter key="Extra_Recycle_Ethane" value="if(parse(%{fresh_feed_change})==-1,&#10;parse(%{sum_del_Feed_flow})/(1+parse(%{shc_ratio}))-parse(%{fresh_feed_quantity}),&#10;%{Extra_Recycle_Ethane})"/>
