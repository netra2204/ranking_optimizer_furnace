                    <parameter key="script" value="import java.io.File;&#10;ExampleSet exampleSet = operator.getInput(ExampleSet.class);&#10;&#10;String userHome = System.getProperty(&quot;user.home&quot;);&#10;File baseDir = new File(userHome);&#10;&#10;File[] folders = baseDir.listFiles(File::isDirectory);&#10;&#10;Attribute folderAttr = AttributeFactory.createAttribute(&quot;folder_name&quot;, Ontology.STRING);&#10;exampleSet.getExampleTable().addAttribute(folderAttr);&#10;exampleSet.getAttributes().addRegular(folderAttr);&#10;// Add folder names to the ExampleSet&#10;int i = 0;&#10;for (Example example : exampleSet) {&#10;   if (folders != null &amp;&amp; i &lt; folders.length) {&#10;       example.setValue(folderAttr, folders[i].getName());&#10;       i++;&#10;   } else {&#10;       // If there are more rows than folders, set empty string&#10;       example.setValue(folderAttr, &quot;&quot;);&#10;   }&#10;}&#10;return exampleSet;"/>
