                                      </operator>
                                      <operator activated="true" class="extract_macro" compatibility="10.4.003" expanded="true" height="68" name="Extract Macro (434)" width="90" x="179" y="136">
                                        <parameter key="macro" value="shc_ratio"/>
                                        <parameter key="macro_type" value="data_value"/>
                                        <parameter key="statistics" value="average"/>
                                        <parameter key="attribute_name" value="shc_ratio"/>
                                        <parameter key="example_index" value="1"/>
                                        <list key="additional_macros"/>
                                        <description align="center" color="transparent" colored="false" width="126">SHC Ratio</description>
                                      </operator>
                                      <operator activated="true" class="filter_examples" compatibility="10.4.003" expanded="true" height="103" name="Filter Examples (346)" width="90" x="313" y="34">
                                        <parameter key="parameter_expression" value=""/>
                                        <parameter key="condition_class" value="custom_filters"/>
                                        <parameter key="invert_filter" value="false"/>
                                        <list key="filters_list">
                                          <parameter key="filters_entry_key" value="Furnace_condition.equals.Good"/>
                                        </list>
                                        <parameter key="filters_logic_and" value="false"/>
                                        <parameter key="filters_check_metadata" value="true"/>
                                        <description align="left" color="transparent" colored="false" width="126">Furnace_condition&lt;br&gt;= Good&lt;br&gt;</description>
                                      </operator>
                                      <operator activated="true" class="blending:generate_columns" compatibility="10.4.003" expanded="true" height="82" name="Generate Attributes (833)" width="90" x="447" y="34">
                                        <list key="function_descriptions">
                                          <parameter key="Margin_condition_type" value="if(Margin_in_Feed==1 &amp;&amp; Margin_in_Feed_lower_check==0,0,&#10;if(Margin_in_Feed==1 &amp;&amp; Margin_in_Feed_lower_check==1,1,1000))"/>
                                          <parameter key="upper_limit_feed" value="if(parse(%{ethane_feed_saturator_drum_overhead_pressure})&#10;&gt;parse(%{saturator_drum_pressure_margin_limit}),&#10;if(Margin_condition_type==1,4,if(Margin_condition_type==0,2,0)),&#10;if(Margin_condition_type==1,2,if(Margin_condition_type==0,1,0)))"/>
                                          <parameter key="max_potential_total_feed" value="floor(min(4,parse(%{pass_step_change})*sum(&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass1_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass1],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass2_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass2],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass3_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass3],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass4_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass4],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass5_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass5],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass6_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass6],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass7_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass7],&#10;floor(max(0,(parse(%{threshold_pass_mixed_feed_limit})-[pass8_mixedfeed_flow]))/parse(%{pass_step_change}))*[upper_feed_condition_pass8])))"/>
                                          <parameter key="max_potential_total_feed" value="if([max_potential_total_feed]==3,2,[max_potential_total_feed])"/>
                                          <parameter key="upper_limit_feed" value="min([upper_limit_feed],[max_potential_total_feed])"/>
                                          <parameter key="step_size_feed" value="if([upper_limit_feed]&gt;1,2,[upper_limit_feed])"/>
                                          <parameter key="Furnace_condition2" value="[Furnace_condition]"/>
                                        </list>
