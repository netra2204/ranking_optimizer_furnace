                                                    <parameter key="define_query" value="query"/>
                                                    <parameter key="query" value="SELECT *&#10;FROM &quot;dbo&quot;.&quot;Furnace_Output&quot; FO With(NOLOCK)&#10;LEFT JOIN &quot;dbo&quot;.&quot;tag&quot; T&#10;ON FO.tag_id = T.tag_id&#10;WHERE FO.model_id = 480&#10;AND FO.time_stamp ='%{prev_Timestamp_final_output2}'&#10;AND T.name LIKE 'un.olf.fur.Ethane_feed_Saturator_Drum_Overhead_Pressure'"/>
