                        <description align="center" color="yellow" colored="true" width="126">Past hour Feed and Conversion is compared with current , if there is no devation above a certain threshold , then past time ranking result is called from DB and used as current output , bypassing the optimization process</description>
                      </operator>
                      <operator activated="true" class="subprocess" compatibility="10.4.003" expanded="true" height="103" name="Ranking optimizaion main" width="90" x="1184" y="136">
                        <process expanded="true">
                          <operator activated="true" class="generate_macro" compatibility="10.4.003" expanded="true" height="82" name="bias final decider" width="90" x="112" y="34">
                            <list key="function_descriptions">
                              <parameter key="final_run_optimizer_check" value="if(parse(%{deviation_exists})==1,parse(%{final_run_optimizer_check_init}),0)"/>
                              <parameter key="sum_del_ethylene_final" value="0"/>
                            </list>
                            <description align="center" color="transparent" colored="false" width="126">final_run_&lt;br/&gt;optimizer_check</description>
                          </operator>
                          <operator activated="true" class="branch" compatibility="10.4.003" expanded="true" height="82" name="MAIN" width="90" x="313" y="34">
                            <parameter key="condition_type" value="expression"/>
                            <parameter key="expression" value="parse(%{final_run_optimizer_check})==1"/>
                            <parameter key="io_object" value="ANOVAMatrix"/>
                            <parameter key="return_inner_output" value="true"/>
                            <process expanded="true">
                              <operator activated="true" class="subprocess" compatibility="10.4.003" expanded="true" height="82" name="main" width="90" x="112" y="34">
                                <process expanded="true">
                                  <operator activated="true" class="subprocess" compatibility="10.4.003" expanded="true" height="82" name="Pre Grid" width="90" x="112" y="34">
                                    <process expanded="true">
                                      <operator activated="true" class="blending:generate_columns" compatibility="10.4.003" expanded="true" height="82" name="Generate Attributes (906)" width="90" x="45" y="34">
                                        <list key="function_descriptions">
                                          <parameter key="lower_limit_feed" value="0"/>
                                          <parameter key="upper_limit_feed" value="0"/>
                                          <parameter key="flag_conversion_part_override" value="0"/>
                                          <parameter key="step_size_conversion" value="0"/>
                                          <parameter key="Ethane_Feed" value="[Feed_flow]/(1+[shc_ratio])"/>
                                          <parameter key="Current_Recycle_Ethane_Feed" value="[Ethane_Feed]*(100-[Overall_conversion])/100"/>
                                          <parameter key="factor" value="if([percent_above_threshold]&gt;0,1/[Overall_conversion],-1*[Overall_conversion])"/>
                                          <parameter key="feed_reduction_potential" value="floor(min(4,parse(%{pass_step_change})*sum(&#10;floor(max(0,([pass1_mixedfeed_flow]-parse(%{pass_feed_min_limit})))/parse(%{pass_step_change}))*[pass1_feed_red_potential_on_min_days],&#10;floor(max(0,([pass2_mixedfeed_flow]-parse(%{pass_feed_min_limit})))/parse(%{pass_step_change}))*[pass2_feed_red_potential_on_min_days],&#10;floor(max(0,([pass3_mixedfeed_flow]-parse(%{pass_feed_min_limit})))/parse(%{pass_step_change}))*[pass3_feed_red_potential_on_min_days],&#10;floor(max(0,([pass4_mixedfeed_flow]-parse(%{pass_feed_min_limit})))/parse(%{pass_step_change}))*[pass4_feed_red_potential_on_min_days],&#10;floor(max(0,([pass5_mixedfeed_flow]-parse(%{pass_feed_min_limit})))/parse(%{pass_step_change}))*[pass5_feed_red_potential_on_min_days],&#10;floor(max(0,([pass6_mixedfeed_flow]-parse(%{pass_feed_min_limit})))/parse(%{pass_step_change}))*[pass6_feed_red_potential_on_min_days],&#10;floor(max(0,([pass7_mixedfeed_flow]-parse(%{pass_feed_min_limit})))/parse(%{pass_step_change}))*[pass7_feed_red_potential_on_min_days],&#10;floor(max(0,([pass8_mixedfeed_flow]-parse(%{pass_feed_min_limit})))/parse(%{pass_step_change}))*[pass8_feed_red_potential_on_min_days])))"/>
                                          <parameter key="feed_reduction_potential" value="if([feed_reduction_potential]==3,2,[feed_reduction_potential])"/>
                                        </list>
                                        <parameter key="keep_all_columns" value="true"/>
                                        <parameter key="default_time_zone" value="Asia/Riyadh"/>
                                        <description align="center" color="transparent" colored="false" width="126">pre calcs</description>
                                      </operator>
                                      <operator activated="true" class="extract_macro" compatibility="10.4.003" expanded="true" height="68" name="Number_of_rows (11)" width="90" x="179" y="34">
                                        <parameter key="macro" value="Number_of_rows"/>
                                        <parameter key="macro_type" value="number_of_examples"/>
