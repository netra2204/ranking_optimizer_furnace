                                  <parameter key="recycle_change_possible" value="if(parse(%{want_to_change_recycle_feed_flow})==1 &amp;&amp; &#13;&#10;parse(%{recycle_ethane_controller_margin})==1, 1,0)"/>
                                  <parameter key="biasing_condition" value="if(parse(%{count_of_good_fur})==0,3,&#10;if(parse(%{recycle_change_possible})==1,1,2))"/>
                                  <parameter key="fresh_feed_quantity" value="parse(%{fresh_feed_change})*&#10;abs(parse(%{expected_fresh_feed})-parse(%{ethane_feed_flow_from_aramco}))/0.6618"/>
                                  <parameter key="deviation_in_aramco" value="if(parse(%{ethane_feed_flow_from_aramco_past_time})==0,0,&#10;parse(%{ethane_feed_flow_from_aramco})-parse(%{ethane_feed_flow_from_aramco_past_time}))"/>
                                  <parameter key="fresh_feed_deviation_check" value="if((if(parse(%{fresh_feed_change})==0 &amp;&amp; &#10;abs(parse(%{deviation_in_aramco}))&gt;parse(%{ethane_feed_flow_aramco_limit}),0,1))==1&#10;&amp;&amp; &#10;(if(parse(%{fresh_feed_change})!=0 &amp;&amp; &#10;parse(%{deviation_in_aramco})&lt;-1,0,1))==1,1,0)"/>
                                  <parameter key="total_optimizer_run_check" value="if(parse(%{minimum_cracking_furnace_available_check})==1 &#10;&amp;&amp;&#10;parse(%{fresh_feed_deviation_check})==1 ,1,0)"/>
                                  <parameter key="min_fur_skip_check_bias2" value="if(parse(%{biasing_condition})==2 &amp;&amp;&#10;parse(%{total_fur_available_for_bias})==1 , 0,1)"/>
                                </list>
                                <description align="left" color="transparent" colored="false" width="126">pre checks before bias</description>
