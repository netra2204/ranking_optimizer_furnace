                                              <parameter key="step_size_feed" value="if(parse(%{biasing_condition})==1 &amp;&amp; &#10;parse(%{mixed_feed_margin})==parse(%{sum_upper_limit_feed}),&#10;if([step_size_feed]==0,0,1),[step_size_feed])"/>
