                                                <parameter key="database_system" value="MySQL"/>
                                                <parameter key="define_query" value="query"/>
                                                <parameter key="query" value="SELECT a.time_stamp,a.model_id,b.name_short,a.actual&#10;FROM &quot;dbo&quot;.&quot;Furnace_Output&quot; a with(nolock)&#10;join &quot;dbo&quot;.&quot;Tag&quot; b with(nolock)&#10;on a.tag_id=b.tag_id&#10;where a.time_stamp=DATEADD(hour,-1,'%{end_time}') and&#10;a.model_id =480&#10;and lower(b.name_short) like '%pass%coke%thickness%'"/>
