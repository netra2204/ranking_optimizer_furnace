                                                                  <parameter key="flag_benefit" value="flag_benefit"/>
                                                                </list>
                                                                <description align="left" color="transparent" colored="false" width="126">flags for calculating Max benefit</description>
                                                              </operator>
                                                              <operator activated="true" class="generate_macro" compatibility="10.4.003" expanded="true" height="68" name="Generate Macro (44)" width="90" x="849" y="187">
                                                                <list key="function_descriptions">
                                                                  <parameter key="Max_Benefit" value="if(&#10;parse(%{sum_Change_in_Recycle_Ethane_Feed})&gt;=parse(%{lower_limit_change_in_recycle_ethane}) &amp;&amp;&#10;parse(%{sum_Change_in_Recycle_Ethane_Feed})&lt;=parse(%{upper_limit_change_in_recycle_ethane}) &amp;&amp; &#10;parse(%{flag_benefit})==1 &amp;&amp;&#10;parse(%{flag_energy_consumption})==1 &amp;&amp;&#10;parse(%{flag_specific_energy_consumption})==1&#10;,parse(%{sum_del_ethylene}),parse(%{Max_Benefit}))"/>
                                                                </list>
