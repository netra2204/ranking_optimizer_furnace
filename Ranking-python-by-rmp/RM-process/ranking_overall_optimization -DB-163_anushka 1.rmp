                                                              <operator activated="true" class="generate_macro" compatibility="10.4.003" expanded="true" height="68" name="Generate Macro (23)" width="90" x="246" y="289">
                                                                <list key="function_descriptions">
                                                                  <parameter key="flag_SPC" value="if(parse(%{curr_sum_SPC_Furnace})&lt;parse(%{Max_Benefit_SPC}),1,0)"/>
                                                                  <parameter key="benefit_percent_upper" value="1+parse(%{benefit_percent_threshold})"/>
                                                                  <parameter key="benefit_percent_lower" value="1-parse(%{benefit_percent_threshold})"/>
                                                                </list>
                                                                <description align="left" color="transparent" colored="false" width="126">flag_SPC&lt;br&gt;benefit_percent_upper&lt;br&gt;benefit_percent_lower</description>
                                                              </operator>
                                                              <operator activated="true" class="blending:generate_columns" compatibility="10.4.003" expanded="true" height="82" name="Generate Attributes (54)" width="90" x="447" y="289">
                                                                <list key="function_descriptions">
                                                                  <parameter key="sum(Current_specific_energy_consumption)" value="[sum(Heat)]/[sum(Temp_Ethylene_Production)]"/>
                                                                  <parameter key="sum(New_specific_energy_consumption)" value="[sum(Heat_new)]/[sum(New_Ethylene_Production)]"/>
                                                                  <parameter key="flag_energy_consumption" value="if(parse(%{ranking_improve_energy_consumption})==0,1,&#10;if([sum(Heat_new)]&lt;=[sum(Heat)],1,0))"/>
                                                                  <parameter key="flag_specific_energy_consumption" value="if(parse(%{ranking_improve_specific_energy_consumption})==0,1,&#10;if([sum(New_specific_energy_consumption)]&lt;=[sum(Current_specific_energy_consumption)],1,0))"/>
                                                                  <parameter key="flag_benefit" value="if(parse(%{sum_del_ethylene})&gt;parse(%{Max_Benefit})*parse(%{benefit_percent_upper}),1,&#13;&#10;if(parse(%{sum_del_ethylene})&gt;parse(%{Max_Benefit})*parse(%{benefit_percent_lower}) &amp;&amp;&#13;&#10;parse(%{sum_del_ethylene})&lt;parse(%{Max_Benefit})*parse(%{benefit_percent_upper}) &amp;&amp; &#13;&#10;parse(%{flag_SPC})==1&#13;&#10;,1,0))"/>
                                                                </list>
                                                                <parameter key="keep_all_columns" value="true"/>
                                                                <parameter key="default_time_zone" value="Asia/Riyadh"/>
                                                                <description align="left" color="transparent" colored="false" width="126">flag_specific&lt;br&gt;_energy_consumption&lt;br&gt;flag_energy_consumption&lt;br&gt;flag_benefit</description>
                                                              </operator>
